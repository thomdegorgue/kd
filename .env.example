# ─── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Mercado Pago ───────────────────────────────────────────────
# Obtener de https://www.mercadopago.com.ar/developers → Mis aplicaciones → Credentials
# Usar TEST-... para sandbox, APP_USR-... para producción
MP_ACCESS_TOKEN=TEST-...
MP_PUBLIC_KEY=TEST-...
# Obtener del webhook configurado en MP dashboard
MP_WEBHOOK_SECRET=

# ─── Cloudinary ────────────────────────────────────────────────
# Obtener de https://cloudinary.com → Dashboard → Cloud Name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# Upload preset de tipo Unsigned, nombre "kitdigital", folder "kitdigital"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=kitdigital

# ─── Upstash Redis ─────────────────────────────────────────────
# Obtener de https://upstash.com → tu base de datos → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── OpenAI ────────────────────────────────────────────────────
# Obtener de https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# ─── Resend (email transaccional) ──────────────────────────────
# Obtener de https://resend.com → API Keys
RESEND_API_KEY=re_...

# ─── App ───────────────────────────────────────────────────────
# En dev: http://localhost:3000 | En prod: https://kitdigital.ar
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En dev: localhost:3000 | En prod: kitdigital.ar
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# ─── Cron (REQUERIDO en producción) ────────────────────────────
# Generar con: openssl rand -base64 32
# Configurar también en Vercel → Settings → Environment Variables
CRON_SECRET=
