{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.kitdigital.ar"
        }
      ],
      "destination": "https://kitdigital.ar/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-billing",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/clean-assistant-sessions",
      "schedule": "0 4 * * *"
    }
  ]
}
